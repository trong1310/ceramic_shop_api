<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<targets>
		<target name="logfile" xsi:type="File" fileName="${logDirectory}/netcore.log"
				layout="${longdate}|${logger}|${aspnet-mvc-action}:${callsite-linenumber}|${level:uppercase=true}:${message} ${exception:format=tostring}" />
		<target name="logconsole" xsi:type="Console" />
	</targets>

	<rules>
		<logger name="*" minlevel="Info" writeTo="logconsole" />
		<logger name="*" minlevel="Debug" writeTo="logfile" />
		<logger name="*" minlevel="ERR" writeTo="logfile" />
	</rules>
</nlog>